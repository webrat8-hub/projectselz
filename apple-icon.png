@import 'tailwindcss';
@import 'tw-animate-css';

@custom-variant dark (&:is(.dark *));

:root {
  --background: oklch(0.12 0.02 250);
  --foreground: oklch(0.98 0 0);
  --card: oklch(0.15 0.025 250);
  --card-foreground: oklch(0.98 0 0);
  --popover: oklch(0.15 0.025 250);
  --popover-foreground: oklch(0.98 0 0);
  --primary: oklch(0.7 0.18 195);
  --primary-foreground: oklch(0.12 0.02 250);
  --secondary: oklch(0.2 0.03 250);
  --secondary-foreground: oklch(0.98 0 0);
  --muted: oklch(0.25 0.02 250);
  --muted-foreground: oklch(0.65 0.02 250);
  --accent: oklch(0.65 0.2 160);
  --accent-foreground: oklch(0.12 0.02 250);
  --destructive: oklch(0.55 0.25 25);
  --destructive-foreground: oklch(0.98 0 0);
  --border: oklch(0.3 0.04 250);
  --input: oklch(0.18 0.03 250);
  --ring: oklch(0.7 0.18 195);
  --chart-1: oklch(0.7 0.18 195);
  --chart-2: oklch(0.65 0.2 160);
  --chart-3: oklch(0.55 0.25 25);
  --chart-4: oklch(0.75 0.15 280);
  --chart-5: oklch(0.8 0.18 85);
  --radius: 1rem;
  
  /* Cyberpunk colors */
  --cyan: oklch(0.7 0.18 195);
  --green: oklch(0.65 0.2 160);
  --red: oklch(0.55 0.25 25);
  --purple: oklch(0.6 0.2 280);
}

.dark {
  --background: oklch(0.12 0.02 250);
  --foreground: oklch(0.98 0 0);
  --card: oklch(0.15 0.025 250);
  --card-foreground: oklch(0.98 0 0);
  --popover: oklch(0.15 0.025 250);
  --popover-foreground: oklch(0.98 0 0);
  --primary: oklch(0.7 0.18 195);
  --primary-foreground: oklch(0.12 0.02 250);
  --secondary: oklch(0.2 0.03 250);
  --secondary-foreground: oklch(0.98 0 0);
  --muted: oklch(0.25 0.02 250);
  --muted-foreground: oklch(0.65 0.02 250);
  --accent: oklch(0.65 0.2 160);
  --accent-foreground: oklch(0.12 0.02 250);
  --destructive: oklch(0.55 0.25 25);
  --destructive-foreground: oklch(0.98 0 0);
  --border: oklch(0.3 0.04 250);
  --input: oklch(0.18 0.03 250);
  --ring: oklch(0.7 0.18 195);
}

@theme inline {
  --font-sans: 'Orbitron', 'Geist', sans-serif;
  --font-mono: 'Geist Mono', monospace;
  --color-background: var(--background);
  --color-foreground: var(--foreground);
  --color-card: var(--card);
  --color-card-foreground: var(--card-foreground);
  --color-popover: var(--popover);
  --color-popover-foreground: var(--popover-foreground);
  --color-primary: var(--primary);
  --color-primary-foreground: var(--primary-foreground);
  --color-secondary: var(--secondary);
  --color-secondary-foreground: var(--secondary-foreground);
  --color-muted: var(--muted);
  --color-muted-foreground: var(--muted-foreground);
  --color-accent: var(--accent);
  --color-accent-foreground: var(--accent-foreground);
  --color-destructive: var(--destructive);
  --color-destructive-foreground: var(--destructive-foreground);
  --color-border: var(--border);
  --color-input: var(--input);
  --color-ring: var(--ring);
  --color-chart-1: var(--chart-1);
  --color-chart-2: var(--chart-2);
  --color-chart-3: var(--chart-3);
  --color-chart-4: var(--chart-4);
  --color-chart-5: var(--chart-5);
  --color-cyan: var(--cyan);
  --color-green: var(--green);
  --color-red: var(--red);
  --color-purple: var(--purple);
  --radius-sm: calc(var(--radius) - 4px);
  --radius-md: calc(var(--radius) - 2px);
  --radius-lg: var(--radius);
  --radius-xl: calc(var(--radius) + 4px);
}

@layer base {
  * {
    @apply border-border outline-ring/50;
  }
  body {
    @apply bg-background text-foreground;
  }
}

/* Glassmorphism utilities */
.glass {
  background: rgba(20, 30, 50, 0.6);
  backdrop-filter: blur(20px);
  -webkit-backdrop-filter: blur(20px);
  border: 1px solid rgba(100, 200, 255, 0.15);
}

.glass-card {
  background: linear-gradient(
    135deg,
    rgba(25, 35, 55, 0.8) 0%,
    rgba(15, 25, 45, 0.9) 100%
  );
  backdrop-filter: blur(24px);
  -webkit-backdrop-filter: blur(24px);
  border: 1px solid rgba(100, 200, 255, 0.2);
  box-shadow: 
    0 8px 32px rgba(0, 0, 0, 0.4),
    inset 0 1px 0 rgba(255, 255, 255, 0.05);
}

.glow-cyan {
  box-shadow: 0 0 20px rgba(0, 200, 255, 0.3), 0 0 40px rgba(0, 200, 255, 0.1);
}

.glow-green {
  box-shadow: 0 0 20px rgba(0, 255, 150, 0.3), 0 0 40px rgba(0, 255, 150, 0.1);
}

.glow-red {
  box-shadow: 0 0 20px rgba(255, 80, 80, 0.3), 0 0 40px rgba(255, 80, 80, 0.1);
}

.text-glow-cyan {
  text-shadow: 0 0 10px rgba(0, 200, 255, 0.5), 0 0 20px rgba(0, 200, 255, 0.3);
}

.text-glow-green {
  text-shadow: 0 0 10px rgba(0, 255, 150, 0.5), 0 0 20px rgba(0, 255, 150, 0.3);
}

.text-glow-red {
  text-shadow: 0 0 10px rgba(255, 80, 80, 0.5), 0 0 20px rgba(255, 80, 80, 0.3);
}

/* Bokeh background effect */
.bokeh-bg {
  position: relative;
  overflow: hidden;
}

.bokeh-bg::before {
  content: '';
  position: absolute;
  inset: 0;
  background: 
    radial-gradient(circle at 20% 20%, rgba(0, 200, 255, 0.15) 0%, transparent 40%),
    radial-gradient(circle at 80% 30%, rgba(0, 255, 150, 0.1) 0%, transparent 35%),
    radial-gradient(circle at 40% 80%, rgba(100, 150, 255, 0.12) 0%, transparent 45%),
    radial-gradient(circle at 90% 80%, rgba(0, 200, 255, 0.08) 0%, transparent 30%),
    radial-gradient(circle at 10% 60%, rgba(150, 100, 255, 0.08) 0%, transparent 35%);
  pointer-events: none;
  z-index: 0;
}

/* Animated pulse */
@keyframes pulse-glow {
  0%, 100% {
    opacity: 1;
  }
  50% {
    opacity: 0.6;
  }
}

.animate-pulse-glow {
  animation: pulse-glow 2s ease-in-out infinite;
}
